{
  "name": "recycle-erp",
  "version": "1.16.1",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --stream run dev",
    "dev:backend": "pnpm --filter recycle-erp-backend dev",
    "dev:frontend": "pnpm --filter recycle-erp-frontend dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "release": "scripts/release.sh",
    "release:deploy": "scripts/release.sh --deploy",
    "db:migrate": "pnpm --filter recycle-erp-backend db:migrate",
    "db:seed": "pnpm --filter recycle-erp-backend db:seed",
    "db:reset": "pnpm --filter recycle-erp-backend db:reset"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  }
}
