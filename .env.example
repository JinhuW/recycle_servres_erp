# Copy to `.env` (repo root) and fill in. Single source of truth for both
# the Docker stack (Compose interpolation + backend env_file) and host-side
# `pnpm dev` / scripts (loaded via apps/backend/scripts/load-env.mjs).
#
# Everything below is optional — Compose + the backend image bake dev defaults
# so a fresh clone runs `docker compose up` with no .env file at all.

# ── Postgres ────────────────────────────────────────────────────────────────
# Default `recycle` if unset. Override for prod.
POSTGRES_PASSWORD=recycle
# Read-only metrics role used by postgres-exporter (created in migration 0042).
POSTGRES_METRICS_PASSWORD=metrics

# ── Backend runtime ────────────────────────────────────────────────────────
# In Docker, docker-compose.yml's `environment:` overrides DATABASE_URL with
# `postgres:5432` over the compose network — the localhost value below is for
# host-side `pnpm dev`.
DATABASE_URL=postgres://recycle:recycle@localhost:5432/recycle_erp
TEST_DATABASE_URL=postgres://recycle:recycle@localhost:5432/recycle_erp_test

# `production` on real servers — turns on the CORS_ALLOWED_ORIGINS guard and
# disables `/api/auth/demo-accounts`. Dockerfile ENV defaults to `development`.
# NODE_ENV=production

# Demo-accounts endpoint (/api/auth/demo-accounts) lists usernames — must be
# disabled in production to prevent user enumeration. Dev image defaults to true.
# ENABLE_DEMO_ACCOUNTS=false

JWT_SECRET=dev-secret-change-me
# JWT_ISSUER=recycle-erp                                   # optional, defaults to recycle-erp

# CORS: unset = permissive (reflects any origin) for local dev. In prod set
# this to the real frontend origin(s), comma-separated.
# CORS_ALLOWED_ORIGINS=https://erp.recycleservers.com

# ── Default admin user ─────────────────────────────────────────────────────
# Created on first boot by scripts/init-admin.mjs (idempotent). Once the row
# exists, changing these has NO effect — change the password from inside the app.
ADMIN_EMAIL=admin@recycle.local
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin
ADMIN_ROLE=manager                                          # 'manager' or 'purchaser'

# ── Label OCR (OpenRouter) ─────────────────────────────────────────────────
# Required in prod; a deterministic stub fires when this is unset.
OPENROUTER_API_KEY=
# OPENROUTER_OCR_MODEL=google/gemini-2.0-flash-001         # or anthropic/claude-sonnet-4.5, openai/gpt-4o

# ── Cloudflare R2 (scan + attachment storage) ──────────────────────────────
# Without real creds, /api/scan/label returns 502 (stub fallback only when
# fully absent).
#
# These values are produced by Terraform — see
# `infra/terraform/environments/prod/README.md`. After `terraform apply`:
#
#   cd infra/terraform/environments/prod
#   terraform output -raw r2_s3_endpoint        # → R2_S3_ENDPOINT
#   terraform output -raw bucket_name           # → R2_BUCKET
#   terraform output -raw public_url            # → R2_ATTACHMENTS_PUBLIC_URL
#   terraform output -raw r2_access_key_id      # → R2_ACCESS_KEY_ID
#   terraform output -raw r2_secret_access_key  # → R2_SECRET_ACCESS_KEY
#
# `CLOUDFLARE_API_TOKEN` (account-scoped, used by Terraform to provision the
# bucket + custom domain + token) is DELIBERATELY not here — keep it in your
# shell when running `terraform apply`. The backend never needs it; it talks
# to R2 over the S3 API using the keys above.
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=recycle-erp-attachments
R2_ATTACHMENTS_PUBLIC_URL=https://static.recycleservers.com

# OAuth 2.1 (powers the MCP read + scraper write surfaces).
# Generate Ed25519 keypair: openssl genpkey -algorithm ed25519 | base64 -w0
#
# OAUTH_ISSUER_URL is the public origin handed to MCP clients in the discovery
# documents (authorize/token/register endpoints + protected resource). It is
# now OPTIONAL: in production the issuer is resolved from CORS_ALLOWED_ORIGINS
# (the allowlist of public origins this server answers for), so behind Caddy it
# advertises the real public URL automatically and never trusts a raw request
# Host. Set OAUTH_ISSUER_URL only to pin an explicit issuer — and if you do, use
# the public origin, NOT localhost, e.g.:
#   OAUTH_ISSUER_URL=https://inventory.recycleservers.com
OAUTH_ISSUER_URL=http://localhost:8787
OAUTH_SIGNING_KEY_CURRENT=
OAUTH_SIGNING_KEY_PREVIOUS=
OAUTH_ACCESS_TOKEN_TTL_SEC=900
OAUTH_REFRESH_TOKEN_TTL_SEC=2592000
OAUTH_DCR_OPEN=false
