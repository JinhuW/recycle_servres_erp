#!/usr/bin/env bash
# pre-push — gates before code leaves the machine:
#   1. Changelog: a push containing feat:/fix: commits must also touch CHANGELOG.md.
#   2. Dependency audit: `pnpm audit` when pnpm-lock.yaml changed in the range.
#   3. Static security: high-signal dangerous-code scan over the pushed diff
#      (plus semgrep if it happens to be installed).
# Bypass once with `git push --no-verify`.
set -u

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$DIR/lib/scan.sh"
ROOT="$(git rev-parse --show-toplevel)"
ZERO=0000000000000000000000000000000000000000
fail=0

while read -r local_ref local_oid remote_ref remote_oid; do
  [ "$local_oid" = "$ZERO" ] && continue                       # branch deletion

  if [ "$remote_oid" = "$ZERO" ]; then                          # new branch on remote
    base="$(git merge-base "$local_oid" origin/main 2>/dev/null || echo "$EMPTY_TREE")"
  else
    base="$remote_oid"
  fi
  tip="$local_oid"

  changed="$(git diff --name-only "$base" "$tip" 2>/dev/null || true)"

  # 1. Changelog gate — only when the push carries feat/fix commits.
  subjects="$(git log --format='%s' "${base}..${tip}" 2>/dev/null || true)"
  if printf '%s\n' "$subjects" | grep -Eq '^(feat|fix)(\(.+\))?!?:'; then
    if printf '%s\n' "$changed" | grep -qx 'CHANGELOG.md'; then
      c_grn "✓ changelog updated for feat/fix changes"
    else
      c_red "✗ push has feat/fix commits but CHANGELOG.md was not updated."
      c_yel "  Cut a release: scripts/release.sh <patch|minor|major>"
      c_yel "  or add an entry under '## [Unreleased]' in CHANGELOG.md."
      fail=1
    fi
  fi

  # 2. Dependency audit — only when the lockfile changed (cheap on normal pushes).
  if printf '%s\n' "$changed" | grep -qx 'pnpm-lock.yaml'; then
    if command -v pnpm >/dev/null 2>&1; then
      echo "▸ pre-push: pnpm-lock.yaml changed — running pnpm audit (high+)"
      if ( cd "$ROOT" && pnpm audit --audit-level=high ); then
        c_grn "✓ pnpm audit clean (high/critical)"
      else
        c_red "✗ pnpm audit reported high/critical advisories (or could not complete)."
        c_yel "  Resolve with pnpm update / pnpm audit --fix, or bypass: git push --no-verify"
        fail=1
      fi
    else
      c_yel "! pnpm not found — skipping dependency audit (run it on a machine with pnpm)"
    fi
  fi

  # 3. Static code security over the pushed diff.
  echo "▸ pre-push: scanning changed code for risky patterns"
  if emit_added "$base" "$tip" | scan_static; then
    c_grn "✓ no risky code patterns"
  else
    c_red "✗ Risky code pattern(s) found."
    c_yel "  Mark a reviewed line with a trailing 'nosec', or bypass: git push --no-verify"
    c_yel "  For a deeper review, run the /security-review skill."
    fail=1
  fi

  # Optional: semgrep, only if the dev has it installed. rc 1 = findings (block);
  # rc >=2 = tool/rule-fetch error (skip, don't punish a flaky network).
  if command -v semgrep >/dev/null 2>&1; then
    files="$(printf '%s\n' "$changed" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' || true)"
    if [ -n "$files" ]; then
      echo "▸ pre-push: semgrep scan"
      semgrep scan --quiet --error --config auto $files
      rc=$?
      if [ "$rc" -eq 1 ]; then
        c_red "✗ semgrep found issues"; fail=1
      elif [ "$rc" -ge 2 ]; then
        c_yel "! semgrep could not complete (rc=$rc) — skipping"
      else
        c_grn "✓ semgrep clean"
      fi
    fi
  fi
done

if [ "$fail" -ne 0 ]; then
  c_red "✗ pre-push checks failed — push aborted."
  exit 1
fi
c_grn "✓ pre-push checks passed"
exit 0
