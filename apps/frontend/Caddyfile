:80 {
	encode gzip
	# Vendor tokens appear in URL paths like /v/<token>; prevent Referer leakage.
	header Referrer-Policy "same-origin"
	# API → backend container.
	handle /api/* {
		reverse_proxy backend:8787
	}
	# OAuth surfaces — RFC 8414 discovery + /oauth/{authorize,token,consent,…}.
	handle /oauth/* {
		reverse_proxy backend:8787
	}
	handle /.well-known/* {
		reverse_proxy backend:8787
	}
	# Service Worker: must not be cached by browsers — updates land within one reload.
	@sw path /sw.js
	header @sw {
		Cache-Control "no-cache"
		Service-Worker-Allowed "/"
	}

	# Web manifest: revalidate so manifest edits propagate quickly.
	@manifest path /manifest.webmanifest
	header @manifest Cache-Control "no-cache"

	# Workbox runtime + precache JS: content-hashed, safe to cache hard.
	@workbox path_regexp ^/workbox-[a-f0-9]+\.js$
	header @workbox Cache-Control "public, max-age=31536000, immutable"

	# SPA static assets with history-API fallback.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

:9090 {
	encode gzip
	handle_path /metrics/backend {
		rewrite * /metrics
		reverse_proxy backend:8787
	}
	handle_path /metrics/postgres {
		rewrite * /metrics
		reverse_proxy postgres-exporter:9187
	}
	respond 404
}
