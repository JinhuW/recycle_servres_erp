# Copy to apps/backend/.env and fill in. The backend reads these via
# src/env.ts; tests and scripts/migrate.mjs|seed.mjs read DATABASE_URL /
# TEST_DATABASE_URL directly.

# Runtime environment. Use `production` on servers; `development` for local
# dev (relaxes some guards). Several security checks key off this value.
NODE_ENV=production

# Demo-accounts endpoint (/api/auth/demo-accounts) lists usernames — must be
# disabled in production to prevent user enumeration. Set true only in dev/staging.
ENABLE_DEMO_ACCOUNTS=false

DATABASE_URL=postgres://recycle:recycle@localhost:5432/recycle_erp
# Used by `pnpm test` (tests/helpers/db.ts). Point at a throwaway DB.
TEST_DATABASE_URL=postgres://recycle:recycle@localhost:5432/recycle_erp_test

# Password for the read-only `metrics` Postgres role used by postgres-exporter.
# Defaults to "metrics" if unset (matches migration 0042's dev default).
POSTGRES_METRICS_PASSWORD=metrics

JWT_SECRET=dev-secret-change-me
# JWT_ISSUER=recycle-erp                                   # optional, defaults to recycle-erp

# Default admin user — created on first boot by scripts/init-admin.mjs (idempotent).
# Once the user exists, changing these values has NO effect on the existing row;
# change the password from inside the app instead.
ADMIN_EMAIL=admin@recycle.local
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin
ADMIN_ROLE=manager                                          # 'manager' or 'purchaser'

# CORS: unset = permissive (reflects any origin) for local dev. In prod set
# this to the real frontend origin(s), comma-separated, so credentialed
# requests are only honored from those origins.
# CORS_ALLOWED_ORIGINS=https://erp.recycleservers.com

# Label OCR — required in prod; a stub is used when the key is absent.
OPENROUTER_API_KEY=
# OPENROUTER_OCR_MODEL=google/gemini-2.0-flash-001         # or anthropic/claude-sonnet-4.5, openai/gpt-4o

# R2 (S3-compatible) for scan/attachment storage. Without real creds,
# /api/scan/label returns 502 (stub fallback only when fully absent).
R2_S3_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=recycle-erp-attachments
R2_ATTACHMENTS_PUBLIC_URL=https://static.recycleservers.com
